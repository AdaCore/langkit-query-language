{
  "version" : "2.1.0",
  "runs" : [ {
    "tool" : {
      "driver" : {
        "name" : "LKQL",
        "version" : "lkql <version>",
        "rules" : [ {
          "id" : "custom",
          "name" : "custom",
          "shortDescription" : {
            "text" : "custom"
          },
          "defaultConfiguration" : {
            "parameters" : {
              "bool" : "true",
              "int" : "42",
              "str" : "/"exterior_arg/"",
              "list" : "[false, 32, /"exterior_other_arg/"]"
            }
          }
        } ]
      }
    },
    "invocations" : [ {
      "executionSuccessful" : true
    } ],
    "results" : [ {
      "ruleId" : "custom",
      "message" : {
        "text" : "custom"
      },
      "locations" : [ {
        "physicalLocation" : {
          "artifactLocation" : {
            "uri" : "file://<working-dir>/main.adb"
          },
          "region" : {
            "startLine" : 3,
            "startColumn" : 4,
            "endLine" : 3,
            "endColumn" : 11
          }
        }
      } ]
    } ]
  } ]
}
